{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch API (run tests first)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "test: api controllers",
      "program": "${workspaceFolder}/AlgoRationsProject/AlgoRationsAPI/bin/Debug/net10.0/AlgoRationsAPI.dll",
      "cwd": "${workspaceFolder}/AlgoRationsProject/AlgoRationsAPI",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7083;http://localhost:5171"
      },
      "stopAtEntry": false,
      "console": "internalConsole",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/scalar/v1"
      }
    }
  ]
}